# Copy to .env and fill in (Docker Compose reads .env for ${VAR} substitution).
# Never commit .env — it is gitignored.

# Required for production (same value as config/master.key on your machine).
RAILS_MASTER_KEY=

# Optional — Google OAuth (or use Rails credentials / credentials.yml.enc + master key above).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
